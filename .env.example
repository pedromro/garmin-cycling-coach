# Garmin Connect credentials
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Optional: only needed for LLM explanation mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Your cycling profile
FTP_WATTS=293
BODY_WEIGHT_KG=80
TARGET_EVENT=Endurance / ultra cycling

# Storage
DB_PATH=data/garmin_coach.sqlite3
REPORT_DIR=reports
